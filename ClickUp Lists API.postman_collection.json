          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Save deleted id before clearing, so request 8 can verify 404",
              "pm.collectionVariables.set('deleted_list_id', pm.collectionVariables.get('list_id'));",
              "",
              "// Clean up variable",
              "pm.collectionVariables.set('list_id', '');"
            ]
          }
