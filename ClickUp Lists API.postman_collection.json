    {
      "name": "7. Delete List (teardown lifecycle)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Save deleted id before clearing, so request 8 can verify 404",
              "pm.collectionVariables.set('deleted_list_id', pm.collectionVariables.get('list_id'));",
              "",
              "// Clean up variable",
              "pm.collectionVariables.set('list_id', '');"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/list/{{list_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "list",
            "{{list_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "8. Get List - negative: after delete (404)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// list_id was cleared on delete; re-set it from a saved copy to verify 404.",
              "const deleted = pm.collectionVariables.get('deleted_list_id');",
              "if (deleted) { pm.collectionVariables.set('list_id', deleted); }"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Deleted list is gone or marked deleted', function () {",
              "    if (pm.response.code === 404) {",
              "        pm.expect(pm.response.code).to.eql(404);",
              "    } else {",
              "        // ClickUp may still return 200 from cache right after delete",
              "        const json = pm.response.json();",
              "        const goneSignal = json.deleted === true || json.archived === true || json.err;",
              "        pm.expect(pm.response.code, 'expected 404 or a 200 marking the list deleted')",
              "          .to.be.oneOf([200, 404]);",
              "        pm.expect(goneSignal, 'response should indicate the list is deleted/archived').to.be.ok;",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
