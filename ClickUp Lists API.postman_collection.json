          "listen": "prerequest",
          "script": {
            "exec": [
              "// list_id was cleared on delete; re-set it from a saved copy if you want to verify 404.",
              "// We saved the deleted id below in the previous request's test if needed.",
              "const deleted = pm.collectionVariables.get('deleted_list_id');",
              "if (deleted) { pm.collectionVariables.set('list_id', deleted); }"
            ],
            "type": "text/javascript",
            "packages": {},
