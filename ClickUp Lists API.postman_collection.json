    "name": "ClickUp Lists API",
    "description": "Tests for ClickUp List endpoints: getLists, createList, getList, updateList, deleteList. Running the whole collection performs a full lifecycle: create -> verify -> update -> negative checks -> delete.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
