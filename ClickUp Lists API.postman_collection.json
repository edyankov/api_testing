              "pm.test('Name was updated', function () {",
              "    pm.expect(json.name).to.eql(pm.collectionVariables.get('created_list_name'));",
              "});",
              "",
              "pm.test('Id is unchanged', function () {",
              "    pm.expect(String(json.id)).to.eql(pm.collectionVariables.get('list_id'));",
              "});"
            ],
